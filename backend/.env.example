# =============================================================================
# FPL AI Coach - Environment Configuration
# =============================================================================
# Copy this file to .env and update values for your environment.
# NEVER commit .env with real credentials!
# =============================================================================

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# Postgres (recommended for production)
# SECURITY: ALWAYS set a strong password via env var POSTGRES_PASSWORD!
DATABASE_URL=postgresql+psycopg2://fpl:${POSTGRES_PASSWORD:?set_in_env}@127.0.0.1:5432/fpl

# SQLite fallback for local development without Docker
# DATABASE_URL=sqlite:///./fpl.db

# Connection pool settings
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40

# -----------------------------------------------------------------------------
# FPL API Configuration
# -----------------------------------------------------------------------------
FPL_BOOTSTRAP_URL=https://fantasy.premierleague.com/api/bootstrap-static/
FPL_FIXTURES_URL=https://fantasy.premierleague.com/api/fixtures/

# API request timeout (seconds)
FPL_API_TIMEOUT=25

# -----------------------------------------------------------------------------
# Security & Rate Limiting
# -----------------------------------------------------------------------------
# Rate limiting: requests per window
RATE_LIMIT_TIMES=10
RATE_LIMIT_WINDOW_SECONDS=60

# Redis for rate limiting (optional, uses memory if not set)
# REDIS_URL=redis://localhost:6379/0

# Secret key for session signing (generate with: openssl rand -hex 32)
# SECURITY: Change in production!
SECRET_KEY=CHANGE_ME_IN_PRODUCTION_use_openssl_rand_hex_32

# API tokens for protected write/admin endpoints
# SECURITY: set both values to long random tokens in all environments.
API_KEY=CHANGE_ME_STANDARD_API_TOKEN
ADMIN_API_KEY=CHANGE_ME_ADMIN_API_TOKEN

# CORS allowed origins (comma-separated). In production set ONLY your frontend domain(s).
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Protect diagnostics endpoint in production by default.
DIAGNOSTICS_REQUIRE_ADMIN=true

# -----------------------------------------------------------------------------
# Ingest & Cache Settings
# -----------------------------------------------------------------------------
# How often to re-ingest FPL data (minutes)
INGEST_TTL_MINUTES=30

# Gameweek metadata sync check interval (minutes)
GAMEWEEK_META_SYNC_CHECK_MINUTES=30

# Sync before deadline (hours)
GAMEWEEK_PRE_DEADLINE_SYNC_HOURS=24

# Post-matchday buffer (hours)
GAMEWEEK_POST_MATCHDAY_BUFFER_HOURS=2

# -----------------------------------------------------------------------------
# Logging & Observability
# -----------------------------------------------------------------------------
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log format: json (for production), console (for development)
LOG_FORMAT=console

# Enable request timing logging
LOG_REQUEST_TIMING=true

# -----------------------------------------------------------------------------
# ML Model Configuration
# -----------------------------------------------------------------------------
# Model version to use
MODEL_VERSION=xgb_v1

# Auto-train model on startup if missing
ML_AUTO_TRAIN=true

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
# Backend host
HOST=127.0.0.1

# Backend port
PORT=8000

# Environment: development, production
ENVIRONMENT=production

# Enable OpenAPI docs pages (auto-disabled by default in production)
ENABLE_API_DOCS=false

# Enable debug mode (disable in production!)
DEBUG=false
